<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PCEval.Models"
             xmlns:vm="clr-namespace:PCEval.ViewModels"
             x:Class="PCEval.Views.DisplayPage"
             x:DataType="vm:DisplayViewModel"
             BackgroundColor="{AppThemeBinding Light={DynamicResource MicaLight}, Dark={DynamicResource MicaDark}}"
             Title="Display">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Display Evaluator" Style="{DynamicResource TitleLargeText}" />
                <Label Style="{DynamicResource SecondaryText}"
                       Text="How does your display compare to Apple Retina standards?" />
            </VerticalStackLayout>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               Color="{DynamicResource Primary}" />

            <!-- Monitor selector (visible only when >1 monitor) -->
            <Border Style="{DynamicResource FluentSubtleCard}"
                    IsVisible="{Binding HasMultipleMonitors}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Monitor" Style="{DynamicResource CaptionText}" />
                    <Picker ItemsSource="{Binding MonitorNames}"
                            SelectedIndex="{Binding SelectedMonitorIndex}"
                            Title="Select monitor" />
                </VerticalStackLayout>
            </Border>

            <!-- Detected display info -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Detected display info" Style="{DynamicResource SubtitleText}" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="16" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Resolution"     Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Resolution}"   Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Refresh rate"   Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding RefreshRate}"  Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Adaptive sync"  Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding AdaptiveSync}" Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="DCI-P3 gamut"   Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding DciP3Gamut}"   Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="sRGB gamut"     Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding SrgbGamut}"    Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="5" Grid.Column="0" Text="HDR"            Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding HdrTier}"      Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="6" Grid.Column="0" Text="Panel type"     Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding PanelType}"    Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="7" Grid.Column="0" Text="Color profile"  Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="7" Grid.Column="1" Text="{Binding ColorProfile}" Style="{DynamicResource BodyStrongText}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Setup inputs -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Your setup" Style="{DynamicResource SubtitleText}" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="16" RowSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Screen diagonal (in)"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Entry Grid.Row="0" Grid.Column="1"
                               Placeholder="e.g. 27"
                               Keyboard="Numeric"
                               Text="{Binding DiagonalInput}"
                               WidthRequest="120"
                               HorizontalTextAlignment="End" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Viewing distance"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Picker Grid.Row="1" Grid.Column="1"
                                ItemsSource="{Binding ViewingDistanceLabels}"
                                SelectedIndex="{Binding SelectedDistanceIndex}"
                                WidthRequest="200" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Scorecard -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Scorecard vs Apple Retina targets" Style="{DynamicResource SubtitleText}" />

                    <!-- Header row -->
                    <Grid ColumnDefinitions="*,80,80,60" ColumnSpacing="8" Padding="0,4,0,4">
                        <Label Grid.Column="0" Text="Metric" Style="{DynamicResource CaptionText}" />
                        <Label Grid.Column="1" Text="Value"  Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="2" Text="Target" Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="3" Text="Result" Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding ScorecardRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DisplayScorecardRow">
                                <Grid ColumnDefinitions="*,80,80,60" ColumnSpacing="8" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding Metric}" Style="{DynamicResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding Value}"  Style="{DynamicResource BodyText}" HorizontalTextAlignment="End" />
                                    <Label Grid.Column="2" Text="{Binding Target}" Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                                    <Label Grid.Column="3" Text="{Binding Result}"
                                           Style="{DynamicResource BodyStrongText}"
                                           TextColor="{Binding ResultColor}"
                                           HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Overall grade -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="{Binding OverallGrade}"
                           Style="{DynamicResource DisplayText}"
                           TextColor="{Binding OverallColor}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding OverallDesc}"
                           Style="{DynamicResource BodyText}"
                           TextColor="{Binding OverallColor}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
