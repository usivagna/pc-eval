<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PCEval.Views.RetinaCheckerPage"
             Title="Retina Checker">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10" MaximumWidthRequest="500"
                             HorizontalOptions="Center">

            <!-- Title -->
            <Label Text="Retina Display Checker"
                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"
                   Margin="0,0,0,8" />

            <!-- Detected resolution row -->
            <Frame Padding="12" CornerRadius="8" BorderColor="#ddd">
                <Grid ColumnDefinitions="*,*" RowSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0" Text="Detected resolution:"
                           VerticalOptions="Center" TextColor="Gray" />
                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding DetectedResolution}"
                           FontAttributes="Bold" VerticalOptions="Center" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Screen diagonal (inches):"
                           VerticalOptions="Center" TextColor="Gray" />
                    <Entry Grid.Row="1" Grid.Column="1"
                           Placeholder="e.g. 27"
                           Keyboard="Numeric"
                           Text="{Binding DiagonalInput}"
                           VerticalOptions="Center" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Pixel density (PPI):"
                           VerticalOptions="Center" TextColor="Gray" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding PpiDisplay}"
                           FontAttributes="Bold" VerticalOptions="Center" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Viewing distance:"
                           VerticalOptions="Center" TextColor="Gray" />
                    <Picker Grid.Row="3" Grid.Column="1"
                            ItemsSource="{Binding ViewingDistanceLabels}"
                            SelectedIndex="{Binding SelectedDistanceIndex}" />

                    <Label Grid.Row="4" Grid.Column="0" Text="Required min. PPI (retina):"
                           VerticalOptions="Center" TextColor="Gray" />
                    <Label Grid.Row="4" Grid.Column="1" Text="{Binding MinPpiDisplay}"
                           FontAttributes="Bold" VerticalOptions="Center" />

                </Grid>
            </Frame>

            <!-- Separator -->
            <BoxView HeightRequest="1" Color="#ddd" Margin="0,6" />

            <!-- Result -->
            <Label Text="{Binding ResultText}"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="{Binding ResultColor}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Explanation -->
            <Label Text="{Binding ExplanationText}"
                   FontSize="13" TextColor="Gray"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   Margin="0,4,0,16" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
