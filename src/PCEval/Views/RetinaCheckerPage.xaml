<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PCEval.ViewModels"
             x:Class="PCEval.Views.RetinaCheckerPage"
             x:DataType="vm:RetinaCheckerViewModel"
             BackgroundColor="{AppThemeBinding Light={DynamicResource MicaLight}, Dark={DynamicResource MicaDark}}"
             Title="Retina Checker">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16"
                             MaximumWidthRequest="640"
                             HorizontalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Retina Display Checker" Style="{DynamicResource TitleLargeText}" />
                <Label Style="{DynamicResource SecondaryText}"
                       Text="Does your display meet Apple's Retina pixel density at your viewing distance?" />
            </VerticalStackLayout>

            <!-- Setup card -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Display setup" Style="{DynamicResource SubtitleText}" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="16" RowSpacing="12">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Detected resolution"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding DetectedResolution}"
                               Style="{DynamicResource BodyStrongText}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Screen diagonal (in)"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Entry Grid.Row="1" Grid.Column="1"
                               Placeholder="e.g. 27"
                               Keyboard="Numeric"
                               Text="{Binding DiagonalInput}"
                               WidthRequest="120"
                               HorizontalTextAlignment="End" />

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Pixel density (PPI)"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding PpiDisplay}"
                               Style="{DynamicResource BodyStrongText}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Viewing distance"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Picker Grid.Row="3" Grid.Column="1"
                                ItemsSource="{Binding ViewingDistanceLabels}"
                                SelectedIndex="{Binding SelectedDistanceIndex}"
                                WidthRequest="200" />

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="Required min. PPI"
                               Style="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{Binding MinPpiDisplay}"
                               Style="{DynamicResource BodyStrongText}"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Result card -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{Binding ResultText}"
                           Style="{DynamicResource TitleLargeText}"
                           TextColor="{Binding ResultColor}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ExplanationText}"
                           Style="{DynamicResource BodyText}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
