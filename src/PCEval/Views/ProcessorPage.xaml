<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PCEval.Models"
             xmlns:vm="clr-namespace:PCEval.ViewModels"
             x:Class="PCEval.Views.ProcessorPage"
             x:DataType="vm:ProcessorViewModel"
             BackgroundColor="{AppThemeBinding Light={DynamicResource MicaLight}, Dark={DynamicResource MicaDark}}"
             Title="Processor">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Processor Evaluator" Style="{DynamicResource TitleLargeText}" />
                <Label Style="{DynamicResource SecondaryText}"
                       Text="How does your CPU / SoC compare to the Apple M3 Pro baseline?" />
            </VerticalStackLayout>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               Color="{DynamicResource Primary}" />

            <!-- Detected CPU info -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Detected processor info" Style="{DynamicResource SubtitleText}" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="16" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="CPU / SoC"        Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding CpuModel}"     Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Recognised tier"  Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TierLabel}"    Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Vendor"           Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Vendor}"       Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Architecture"     Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Architecture}" Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="Cores"            Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Cores}"        Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="5" Grid.Column="0" Text="Threads"          Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding Threads}"      Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="6" Grid.Column="0" Text="Max frequency"    Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding MaxFreq}"      Style="{DynamicResource BodyStrongText}" />

                        <Label Grid.Row="7" Grid.Column="0" Text="Typical TDP"      Style="{DynamicResource BodyText}" />
                        <Label Grid.Row="7" Grid.Column="1" Text="{Binding TypicalTdp}"   Style="{DynamicResource BodyStrongText}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Scorecard vs M3 Pro -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Scorecard vs Apple M3 Pro" Style="{DynamicResource SubtitleText}" />

                    <Grid ColumnDefinitions="*,80,80,55" ColumnSpacing="8" Padding="0,4">
                        <Label Grid.Column="0" Text="Dimension"  Style="{DynamicResource CaptionText}" />
                        <Label Grid.Column="1" Text="Your score" Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="2" Text="Reference"  Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="3" Text="Result"     Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding DimensionRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProcessorScorecardRow">
                                <VerticalStackLayout Padding="0,6" Spacing="2">
                                    <Grid ColumnDefinitions="*,80,80,55" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{Binding Metric}" Style="{DynamicResource BodyText}" />
                                        <Label Grid.Column="1" Text="{Binding Value}"  Style="{DynamicResource BodyText}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="2" Text="{Binding Target}" Style="{DynamicResource CaptionText}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="3" Text="{Binding Result}"
                                               Style="{DynamicResource BodyStrongText}"
                                               TextColor="{Binding ResultColor}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Label Text="{Binding Insight}"
                                           Style="{DynamicResource CaptionText}"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Strengths & Weaknesses -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Strengths &amp; weaknesses" Style="{DynamicResource SubtitleText}" />

                    <CollectionView ItemsSource="{Binding SummaryRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProcessorScorecardRow">
                                <Grid ColumnDefinitions="110,*" ColumnSpacing="12" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding Metric}"
                                           Style="{DynamicResource BodyStrongText}"
                                           TextColor="{Binding ResultColor}"
                                           VerticalOptions="Start" />
                                    <Label Grid.Column="1" Text="{Binding Value}"
                                           Style="{DynamicResource BodyText}"
                                           LineBreakMode="WordWrap" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Overall grade -->
            <Border Style="{DynamicResource FluentCard}">
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="{Binding OverallGrade}"
                           Style="{DynamicResource DisplayText}"
                           TextColor="{Binding OverallColor}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding OverallVerdict}"
                           Style="{DynamicResource BodyText}"
                           TextColor="{Binding OverallColor}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Footnote -->
            <Label Text="Scores are relative to Apple M3 Pro = 100%. Values are derived from published benchmark data and manufacturer specifications; not independently verified."
                   Style="{DynamicResource CaptionText}"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
