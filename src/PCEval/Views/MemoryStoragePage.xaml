<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PCEval.Models"
             x:Class="PCEval.Views.MemoryStoragePage"
             Title="Memory &amp; Storage">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Title -->
            <Label Text="Memory &amp; Storage Evaluator"
                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="How does your RAM and storage compare to the Apple M3 Pro baseline?"
                   FontSize="13" TextColor="Gray" HorizontalOptions="Center"
                   Margin="0,0,0,8" />

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <!-- Detected memory info -->
            <Frame Padding="12" CornerRadius="8" BorderColor="#ddd">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Detected Memory Info"
                           FontAttributes="Bold" FontSize="15" Margin="0,0,0,4" />

                    <Grid ColumnDefinitions="*,*" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Total RAM:"    TextColor="Gray" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalRam}" FontAttributes="Bold" />

                        <Label Grid.Row="1" Grid.Column="0" Text="RAM Type:"     TextColor="Gray" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding RamType}" FontAttributes="Bold" />

                        <Label Grid.Row="2" Grid.Column="0" Text="RAM Speed:"    TextColor="Gray" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding RamSpeed}" FontAttributes="Bold" />

                        <Label Grid.Row="3" Grid.Column="0" Text="RAM Slots:"    TextColor="Gray" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding RamSlots}" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Detected storage info -->
            <Frame Padding="12" CornerRadius="8" BorderColor="#ddd">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Detected Storage Info"
                           FontAttributes="Bold" FontSize="15" Margin="0,0,0,4" />

                    <Grid ColumnDefinitions="*,*" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Primary Disk:"   TextColor="Gray" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryStorage}" FontAttributes="Bold" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Storage Type:"   TextColor="Gray" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding StorageType}" FontAttributes="Bold" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Drive Model:"    TextColor="Gray" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding StorageModel}" FontAttributes="Bold" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Total Storage:"  TextColor="Gray" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalStorage}" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Scorecard vs M3 Pro -->
            <Frame Padding="12" CornerRadius="8" BorderColor="#ddd">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Scorecard vs Apple M3 Pro"
                           FontAttributes="Bold" FontSize="15" Margin="0,0,0,4" />

                    <!-- Column headers -->
                    <Grid ColumnDefinitions="*,100,100,55" Padding="0,0,0,4">
                        <Label Grid.Column="0" Text="Dimension"   FontAttributes="Bold" FontSize="11" />
                        <Label Grid.Column="1" Text="Your Value"  FontAttributes="Bold" FontSize="11" />
                        <Label Grid.Column="2" Text="Reference"   FontAttributes="Bold" FontSize="11" />
                        <Label Grid.Column="3" Text="Result"      FontAttributes="Bold" FontSize="11" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#ddd" Margin="0,2,0,4" />

                    <!-- Dimension rows -->
                    <CollectionView ItemsSource="{Binding DimensionRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MemoryStorageScorecardRow">
                                <VerticalStackLayout Padding="0,4" Spacing="2">
                                    <Grid ColumnDefinitions="*,100,100,55">
                                        <Label Grid.Column="0" Text="{Binding Metric}"
                                               FontSize="13" />
                                        <Label Grid.Column="1" Text="{Binding Value}"
                                               FontSize="13" />
                                        <Label Grid.Column="2" Text="{Binding Target}"
                                               FontSize="11" TextColor="Gray"
                                               LineBreakMode="WordWrap" />
                                        <Label Grid.Column="3" Text="{Binding Result}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="{Binding ResultColor}" />
                                    </Grid>
                                    <!-- Consumer note -->
                                    <Label Text="{Binding Note}"
                                           FontSize="11" TextColor="Gray"
                                           LineBreakMode="WordWrap"
                                           Margin="0,0,0,4" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Info / upgrade rows -->
            <Frame Padding="12" CornerRadius="8" BorderColor="#ddd">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Additional Info"
                           FontAttributes="Bold" FontSize="15" Margin="0,0,0,4" />

                    <CollectionView ItemsSource="{Binding InfoRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MemoryStorageScorecardRow">
                                <VerticalStackLayout Padding="0,4" Spacing="2">
                                    <Label Text="{Binding Metric}"
                                           FontAttributes="Bold" FontSize="13" />
                                    <Label Text="{Binding Note}"
                                           FontSize="12" TextColor="Gray"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Overall grade -->
            <BoxView HeightRequest="1" Color="#ddd" Margin="0,4" />
            <Label Text="{Binding OverallGrade}"
                   FontSize="48" FontAttributes="Bold"
                   TextColor="{Binding OverallColor}"
                   HorizontalOptions="Center" />
            <Label Text="{Binding OverallVerdict}"
                   FontSize="14" TextColor="{Binding OverallColor}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center" />

            <!-- Footnote -->
            <Label Text="Scores compare against the Apple M3 Pro (18 GB unified memory, 512 GB NVMe SSD, ~7.4 GB/s read). Storage speed is estimated from drive type. Results are for comparison purposes only."
                   FontSize="10" TextColor="Gray"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   Margin="0,8,0,16" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
