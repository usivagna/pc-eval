<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Windows 11 Fluent accent (system blue) ─────────────────── -->
    <Color x:Key="Primary">#0078D4</Color>
    <Color x:Key="PrimaryDark">#4CC2FF</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#005FB8</Color>
    <Color x:Key="SecondaryDarkText">#60CDFF</Color>
    <Color x:Key="Tertiary">#003E92</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <!-- Fluent neutral palette -->
    <Color x:Key="Gray100">#F3F3F3</Color>
    <Color x:Key="Gray150">#EBEBEB</Color>
    <Color x:Key="Gray200">#E5E5E5</Color>
    <Color x:Key="Gray300">#C7C7C7</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#3B3B3B</Color>
    <Color x:Key="Gray700">#2D2D2D</Color>
    <Color x:Key="Gray900">#1C1C1C</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Fluent surfaces -->
    <Color x:Key="MicaLight">#F9F9F9</Color>
    <Color x:Key="MicaDark">#202020</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#2B2B2B</Color>
    <Color x:Key="CardStrokeLight">#E5E5E5</Color>
    <Color x:Key="CardStrokeDark">#1C1C1C</Color>
    <Color x:Key="SubtleFillLight">#F5F5F5</Color>
    <Color x:Key="SubtleFillDark">#272727</Color>

    <!-- Semantic (Win11) -->
    <Color x:Key="PassGreen">#107C10</Color>
    <Color x:Key="ReviewOrange">#B85C00</Color>
    <Color x:Key="FailRed">#C42B1C</Color>
    <Color x:Key="NeutralGray">#605E5C</Color>

</ResourceDictionary>
